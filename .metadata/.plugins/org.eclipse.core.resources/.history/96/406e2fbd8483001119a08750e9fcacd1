#include "buzz_tim.h"

void TIM_TimeBase_Init(TIM_RegMap_t *pTIMx, uint16_t psc, uint32_t arr)
{
	pTIMx->PSC = psc;
	pTIMx->ARR = arr;

	pTIMx->EGR |= (1 << 0);
}

void TIM_Start(TIM_RegMap_t *pTIMx)
{
	pTIMx->CR1 |= (1 << 0);
}

uint32_t TIM_GetElapsedUs(TIM_RegMap_t *pTIMx, uint32_t start_cnt)
{
	uint32_t end_cnt = pTIMx->CNT;

	if (end_cnt >= start_cnt)
	{
		return end_cnt - start_cnt;
	}
	else
	{
		return (pTIMx->ARR + 1) - start_cnt + end_cnt;
	}
}

static volatile uint32_t overflow_count = 0;
static uint16_t pwm_duty = 999;
static int8_t pwm_direction = 1;

void TIM2_IRQHandler(void)
{
	if (TIM2->SR & (1 << 0))
	{
		TIM2->SR &= ~(1 << 0);
		overflow_count++;

		TIM2->CCR1 = pwm_duty;
		pwm_duty += pwm_direction;

		if(pwm_duty >= 999) { pwm_duty = 999; pwm_direction = -1; }
		if(pwm_duty == 0) { pwm_direction = 1; }
	}
}

uint32_t TIM_GetOverflowCount(void)
{
	return overflow_count;
}
TIM_Timestamp_t TIM_GetTimestamp(TIM_RegMap_t *pTIMx)
{
	uint32_t ov1, ov2, cnt;

	do
	{
		ov1 = overflow_count;
		cnt = pTIMx->CNT;
		ov2 = overflow_count;
	} while(ov1 != ov2);

	TIM_Timestamp_t ts = { .overflow_count = ov2, .cnt = cnt };
	return ts;
}
uint32_t TIM_GetElapsedUS_Long(TIM_RegMap_t *pTIMx, TIM_Timestamp_t start)
{
	TIM_Timestamp_t end = TIM_GetTimestamp(pTIMx);
	uint32_t period = pTIMx->ARR + 1;

	if (end.cnt >= start.cnt)
	{
		return (end.overflow_count - start.overflow_count) * period + (end.cnt - start.cnt);
	}
	else
	{
		return (end.overflow_count - start.overflow_count - 1) * period + (period - start.cnt) + end.cnt;
	}
}

static volatile uint32_t tim3_overflow_count = 0;

void TIM3_IRQHandler(void)
{
	if(TIM3->SR & (1 >> 0))
	{
		TIM3->SR &= ~(1 >> 0);
		tim3_overflow_count++;
		GPIOA->ODR ^= (1 << 6);
	}
}

uint32_t TIM_GetTim3OverflowCount(void)
{
	return tim3_overflow_count;
}

void TIM_PWM_Init(TIM_Handle_t *pTIMHandle)
{
	pTIMHandle->pTIMx->PSC = pTIMHandle->TIM_Config.TIM_Prescaler;
	pTIMHandle->pTIMx->ARR = pTIMHandle->TIM_Config.TIM_Period;

	switch(pTIMHandle->TIM_Config.TIM_Channel)
	{
	case 1:
		pTIMHandle->pTIMx->CCMR1 &= ~(0x7 << 4);
		pTIMHandle->pTIMx->CCMR1 |= (0x6 << 4);
		pTIMHandle->pTIMx->CCMR1 |= (pTIMHandle->TIM_Config.TIM_OCPreload << 3);
		pTIMHandle->pTIMx->CCER |= (0x1 << 0);
		pTIMHandle->pTIMx->CCR1 = 0;
		break;
	case 2:
		pTIMHandle->pTIMx->CCMR1 &= ~(0x7 << 12);
		pTIMHandle->pTIMx->CCMR1 |= ~(0x6 << 12);
		pTIMHandle->pTIMx->CCMR1 |= (pTIMHandle->TIM_Config.TIM_OCPreload << 11);
		pTIMHandle->pTIMx->CCER |= ( 0x1 << 4 );
		pTIMHandle->pTIMx->CCR2 = 0;
		break;
	case 3:
		pTIMHandle->pTIMx->CCMR2 &= ~(0x7 << 4);
		pTIMHandle->pTIMx->CCMR2 |= (0x6 << 4);
		pTIMHandle->pTIMx->CCMR2 |= (pTIMHandle->TIM_Config.TIM_OCPreload << 3);
		pTIMHandle->pTIMx->CCER |= (0x1 << 0);
		pTIMHandle->pTIMx->CCR3 = 0;
	case 4:
		pTIMHandle->pTIMx->CCMR2 &= ~(0x7 << 12);
		pTIMHandle->pTIMx->CCMR2 |= ~(0x6 << 12);
		pTIMHandle->pTIMx->CCMR2 |= (pTIMHandle->TIM_Config.TIM_OCPreload << 11);
		pTIMHandle->pTIMx->CCER |= ( 0x1 << 4 );
		pTIMHandle->pTIMx->CCR4 = 0;
	}

	pTIMHandle->pTIMx->CR1 |= (0x1 << 0); // CEN - 반드시 마지막
}
