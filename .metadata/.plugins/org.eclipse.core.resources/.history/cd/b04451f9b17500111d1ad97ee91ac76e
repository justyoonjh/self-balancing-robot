#include "mpu6050.h"
#include "buzz_usart.h"
#include <stdio.h>

void MPU6050_Init(I2C_Handle_t *pI2CHandle)
{
	uint8_t tx_buf[2];

	tx_buf[0] = PWR_MGMT_1;
	tx_buf[1] = 0x00;
	I2C_MasterSendData(pI2CHandle, tx_buf, 2, MPU6050_ADDR, I2C_DISABLE_SR);

	tx_buf[0] = SMPLRT_DIV;
	tx_buf[1] = ODR_10HZ;
	I2C_MasterSendData(pI2CHandle, tx_buf, 2, MPU6050_ADDR, I2C_DISABLE_SR);

	tx_buf[0] = CONFIG;
	tx_buf[1] = 0x01;
	I2C_MasterSendData(pI2CHandle, tx_buf, 2, MPU6050_ADDR, I2C_DISABLE_SR);

	tx_buf[0] = GYRO_CONFIG;
	tx_buf[1] = 0x00;
	I2C_MasterSendData(pI2CHandle, tx_buf, 2, MPU6050_ADDR, I2C_DISABLE_SR);

	tx_buf[0] = ACCEL_CONFIG;
	tx_buf[1] = 0x00;
	I2C_MasterSendData(pI2CHandle, tx_buf, 2, MPU6050_ADDR, I2C_DISABLE_SR);
}


uint8_t MPU6050_ReadWhoAmI(I2C_Handle_t *pI2CHandle)
{
	uint8_t reg_addr = WHO_AM_I;
	uint8_t result = 0;

	I2C_MasterSendData(pI2CHandle, &reg_addr, 1, MPU6050_ADDR, I2C_ENABLE_SR);
	I2C_MasterReceiveData(pI2CHandle, &result, 1, MPU6050_ADDR, I2C_DISABLE_SR);

	return result;
}

int16_t MPU6050_ReadAccelX(I2C_Handle_t *pI2CHandle)
{

	uint8_t buf[2];
	uint8_t reg_addr = ACCEL_XOUT_H;

	I2C_MasterSendData(pI2CHandle, &reg_addr, 1, MPU6050_ADDR, I2C_ENABLE_SR);
	I2C_MasterReceiveData(pI2CHandle, buf, 2, MPU6050_ADDR, I2C_DISABLE_SR);

	return (int16_t)((buf[0] << 8) | buf[1]);
}

void MPU6050_ReadRawData(I2C_Handle_t *pI2CHandle, Raw_Data_t *pData)
{
	uint8_t buf[14];
	uint8_t reg_addr = ACCEL_XOUT_H;

	I2C_MasterSendData(pI2CHandle, &reg_addr, 1, MPU6050_ADDR, I2C_ENABLE_SR);
	I2C_MasterReceiveData(pI2CHandle, buf, 14, MPU6050_ADDR, I2C_DISABLE_SR);

	pData->ax 			= (int16_t)((buf[0] << 8) | buf[1]);
	pData->ay 			= (int16_t)((buf[2] << 8) | buf[3]);
	pData->az 			= (int16_t)((buf[4] << 8) | buf[5]);
	pData->temp_raw 	= (int16_t)((buf[6] << 8) | buf[7]);
	pData->gx 			= (int16_t)((buf[8] << 8) | buf[9]);
	pData->gy 			= (int16_t)((buf[10] << 8) | buf[11]);
	pData->gz			= (int16_t)((buf[12] << 8) | buf[13]);
}

void MPU6050_SendPacket(I2C_Handle_t *pI2CHandle, USART_Handle_t *pUSARTHandle)
{
	Raw_Data_t	raw;
	MPU6050_ReadRawData(pI2CHandle, &raw);

	char payload[64];
	uint8_t plen  = (uint8_t)snprintf(payload, sizeof(payload),
			"AX:%ld,AY:%ld,AZ:%ld,GX:%ld,GY:%ld,GZ:%ld,T:%ld",
			raw.ax,raw.ay,raw.az,raw.gx,raw.gy,raw.gz,(int32_t)(raw.temp_raw / 340) + 36) + 1; // included \0

	uint8_t packet[70];
	packet[0] = PKT_STX;
	packet[1] = plen;
	for(uint8_t i = 0; i < plen; i++)
	{
		packet[2 + i] = (uint8_t)payload[i];
	}
	packet[2 + plen] = PKT_ETX;
	USART_SendData(pUSARTHandle, packet, 2 + plen + 1);
}
