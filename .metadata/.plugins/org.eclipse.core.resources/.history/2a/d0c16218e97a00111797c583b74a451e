#include <stdint.h>
#include <stdio.h>
#include "buzz_gpio.h"
#include "buzz_rcc.h"
#include "buzz_systick.h"
//#include "i2c_scanner.h"
#include "buzz_i2c.h"
#include "buzz_usart.h"
#include "mpu6050.h"
#include "buzz_tim.h"
#include "tim_profiling.h"


int main(void)
{
	TIM2->DIER |= ( 1 << 0 );
	NVIC_ISER0 |= ( 1 << 28 );

	TIM_Timestamp_t start_ts = TIM_GetTimestamp(TIM2);
	for (volatile int i = 0; i < 20000; i++);
	uint32_t elapsed_us = TIM_GetElapsedUS_Long(TIM2, start_ts);
	printf("Long Elapsed: %lu us\r\n", elapsed_us);


}
